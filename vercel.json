{
  "version": 2,
  "buildCommand": "npm install && npm run build 2>/dev/null || true",
  "outputDirectory": ".",
  "routes": [
    {
      "src": "/api/(.*)",
      "methods": ["GET", "POST"],
      "dest": "/api/$1.js"
    },
    {
      "src": "/(.*\\.(js|css|json|html|xml))",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
